# 复制为 .env 后修改：cp .env.example .env

NODE_ENV=production
PORT=5000

# PostgreSQL（需先建库并执行迁移，首次启动自动 migrate + 种子数据）
# 本机直连：
DATABASE_URL=postgresql://api:your_db_password@127.0.0.1:5432/api
# Docker 容器访问宿主机数据库时用：
# DATABASE_URL=postgresql://api:your_db_password@host.docker.internal:5432/api

# Redis（队列、限流、会话；无密码可写 redis://127.0.0.1:6379）
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379
# Docker：
# REDIS_URL=redis://:your_redis_password@host.docker.internal:6379

WORKER_CONCURRENCY=4

# 加密 LLM 提供商 API Key 用，必须 64 位十六进制（32 字节）
# 生成：openssl rand -hex 32
LLM_MASTER_KEY=replace_with_openssl_rand_hex_32
